<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/streamRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <ImageView
        android:id="@+id/tvRemoteCursor"
        android:layout_width="12dp"
        android:layout_height="18dp"
        android:contentDescription="@null"
        android:importantForAccessibility="no"
        android:scaleType="fitXY"
        android:src="@drawable/ic_remote_cursor"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvConnecting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Connecting..."
        android:textColor="@color/white"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvStats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="#88000000"
        android:fontFamily="monospace"
        android:padding="8dp"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:visibility="gone"
        tools:text="LIVE · 192.168.1.20\nVIDEO  1920×1080 @ 60 · H.264\nNET    14000 kbps · loss 0.0%\nAUDIO  48 kHz stereo · 1536 kbps" />

    <TextView
        android:id="@+id/tvStreamStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="16dp"
        android:background="#99000000"
        android:paddingHorizontal="12dp"
        android:paddingVertical="7dp"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:visibility="gone"
        tools:text="LIVE · 1920×1080 @ 60 · audio on"
        tools:visibility="visible" />

    <LinearLayout
        android:id="@+id/mouseToolbar"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_margin="8dp"
        android:background="#99000000"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMouseToggle"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="56dp"
            android:layout_height="48dp"
            android:contentDescription="@string/mouse_toggle_description"
            android:enabled="false"
            android:minWidth="0dp"
            android:paddingHorizontal="2dp"
            android:text="@string/mouse_toggle_on"
            android:textColor="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPointerMode"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="60dp"
            android:layout_height="48dp"
            android:contentDescription="@string/mouse_mode_change_description"
            android:enabled="false"
            android:minWidth="0dp"
            android:paddingHorizontal="2dp"
            android:text="@string/mouse_mode_pad"
            android:textColor="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMouseClick"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="52dp"
            android:layout_height="48dp"
            android:contentDescription="@string/mouse_click_description"
            android:enabled="false"
            android:minWidth="0dp"
            android:paddingHorizontal="2dp"
            android:text="@string/mouse_click"
            android:textColor="@color/white" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvGestureHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="68dp"
        android:background="#88000000"
        android:gravity="center"
        android:maxWidth="520dp"
        android:paddingHorizontal="10dp"
        android:paddingVertical="7dp"
        android:text="@string/mouse_gesture_hint"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:visibility="gone"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tvGamepadStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_margin="16dp"
        android:background="#88000000"
        android:paddingHorizontal="10dp"
        android:paddingVertical="7dp"
        android:text="Controller: none detected"
        android:textColor="@color/white"
        android:textSize="12sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAudio"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="12dp"
        android:backgroundTint="#99000000"
        android:enabled="false"
        android:minWidth="96dp"
        android:text="Audio…"
        android:textColor="@color/white" />

</FrameLayout>
